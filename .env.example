# ==============================================================================
# Arquivo de Exemplo de Configurações - Monitor de Estoque
# Renomeie este arquivo para .env e preencha com seus dados reais.
# NUNCA envie o arquivo .env para o GitHub!
# ==============================================================================

# CPF do paciente cadastrado (obrigatório para consultar o bot)
BOT_CPF=12345678900

# URL da API do bot (obrigatório)
BOT_BASE_URL=https://[DOMINIO_DO_BOT]/api/v1

# URL referer do chatbot (obrigatório)
BOT_REFERER=https://[DOMINIO_DO_BOT]/

# ID do chatbot Typebot (opcional, caso mude na plataforma da associação)
# BOT_TYPEBOT_ID=pix-pagamento


# ------------------------------------------------------------------------------
# Configurações de Notificação (Opcionais)
# ------------------------------------------------------------------------------

# 1. ntfy.sh: Notificações push para celular (Android/iOS)
# Basta escolher um nome único para o seu tópico e se inscrever no app ntfy.
NTFY_TOPIC=

# 2. Telegram Bot: Notificações via chat no Telegram
# Crie um bot com o @BotFather para obter o TOKEN.
# Use o @userinfobot no Telegram para descobrir seu CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
